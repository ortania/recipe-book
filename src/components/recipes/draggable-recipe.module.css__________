.draggableWrapper {
  transition: all 0.2s ease;
  cursor: grab;
}

.draggableWrapper:active {
  cursor: grabbing;
}

.dragging {
  opacity: 0.5;
  transform: scale(var(--basic-font));
}

.dragOver {
  border: 2px dashed var(--clr-secondary-500);
  border-radius: 12px;
  background: rgba(138, 154, 91, 0.05);
}
