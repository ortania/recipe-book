rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: any logged-in user can read, but only own doc can be written
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Blocked-users subcollection: strictly private to the owner.
      // Each doc id IS the blocked user's uid.
      match /blockedUsers/{blockedUserId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }

    // Recipes: any logged-in user can read & create (create needed for copy-to-user), only owner can update/delete
    match /recipes/{recipeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                            && resource.data.userId == request.auth.uid;

      // Ratings subcollection: each user can rate any recipe
      match /ratings/{ratingUserId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
                     && request.auth.uid == ratingUserId
                     && request.resource.data.rating >= 1
                     && request.resource.data.rating <= 5;
      }

      // Comments subcollection: any logged-in user can read/create, only comment owner can delete
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if request.auth != null
                      && resource.data.userId == request.auth.uid;
      }
    }

    // Categories: owner can read/write; any logged-in user can read categories of public-profile users
    match /categories/{categoryId} {
      allow read: if request.auth != null
                  && (resource.data.userId == request.auth.uid
                      || get(/databases/$(database)/documents/users/$(resource.data.userId)).data.publicProfile == true);
      allow write: if request.auth != null
                   && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
    }

    // Meal plans: only the owner can read/write
    match /mealPlans/{docId} {
      allow read, write: if request.auth != null;
    }

    // API keys (managed by admin/cloud functions)
    match /apiKeys/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // App settings (OpenAI key etc.) — read for logged-in users, write only for admin
    match /appSettings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Community reports: any logged-in user can create a report scoped to
    // their own uid. Reports are write-only from clients; only admins (via
    // Cloud Functions / Firebase console) can read or moderate them.
    match /communityReports/{reportId} {
      allow create: if request.auth != null
                    && request.resource.data.reporterUserId == request.auth.uid
                    && request.resource.data.reason in
                       ['offensive','infringement','misleading','spam','other'];
      allow read, update, delete: if false;
    }
  }
}
