rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Shared predicate: does the caller have a verified email address?
    // Used to gate community-facing writes (sharing recipes, comments,
    // reports) on the server so unverified users can't bypass the
    // client-side gates via direct Firestore calls.
    function emailVerified() {
      return request.auth != null
             && request.auth.token.email_verified == true;
    }

    // Users: any logged-in user can read, but only own doc can be written
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Blocked-users subcollection: strictly private to the owner.
      // Each doc id IS the blocked user's uid.
      match /blockedUsers/{blockedUserId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }

    // Recipes
    //
    // Private recipes (no shareToGlobal flag set to true) can be
    // created/edited by any authenticated user — an unverified user
    // should still be able to use the app for themselves. Recipes that
    // are shared to the community (`shareToGlobal == true`) require a
    // verified email on the caller. That way flipping the share toggle
    // on (create with shareToGlobal=true, or update from false → true)
    // is gated server-side regardless of what the client sends.
    match /recipes/{recipeId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && (request.resource.data.shareToGlobal != true
                        || emailVerified());

      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && (request.resource.data.shareToGlobal != true
                        || emailVerified());

      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;

      // Ratings subcollection: each user can rate any recipe
      match /ratings/{ratingUserId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
                     && request.auth.uid == ratingUserId
                     && request.resource.data.rating >= 1
                     && request.resource.data.rating <= 5;
      }

      // Comments subcollection: reads are public to logged-in users,
      // but writing a comment is a community action — require verified
      // email. Owners can still delete their own comment without being
      // verified (e.g. to remove it after an email bounce).
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && emailVerified();
        allow update: if request.auth != null && emailVerified();
        allow delete: if request.auth != null
                      && resource.data.userId == request.auth.uid;
      }
    }

    // Categories: owner can read/write; any logged-in user can read categories of public-profile users
    match /categories/{categoryId} {
      allow read: if request.auth != null
                  && (resource.data.userId == request.auth.uid
                      || get(/databases/$(database)/documents/users/$(resource.data.userId)).data.publicProfile == true);
      allow write: if request.auth != null
                   && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
    }

    // Meal plans: only the owner can read/write
    match /mealPlans/{docId} {
      allow read, write: if request.auth != null;
    }

    // API keys (managed by admin/cloud functions)
    match /apiKeys/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // App settings (OpenAI key etc.) — read for logged-in users, write only for admin
    match /appSettings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Community reports: any logged-in user with a verified email can
    // create a report scoped to their own uid. Reports are write-only
    // from clients; only admins (via Cloud Functions / Firebase console)
    // can read or moderate them.
    match /communityReports/{reportId} {
      allow create: if request.auth != null
                    && emailVerified()
                    && request.resource.data.reporterUserId == request.auth.uid
                    && request.resource.data.reason in
                       ['offensive','infringement','misleading','spam','other'];
      allow read, update, delete: if false;
    }
  }
}
