# OpenAI API Configuration
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Cloud Function URLs (replace project ID if you deploy to a different Firebase project)
VITE_CLOUD_CHAT_URL=https://us-central1-YOUR_PROJECT_ID.cloudfunctions.net/openaiChat
VITE_CLOUD_TTS_URL=https://us-central1-YOUR_PROJECT_ID.cloudfunctions.net/openaiTts
VITE_CLOUD_OCR_URL=https://us-central1-YOUR_PROJECT_ID.cloudfunctions.net/ocrImage
VITE_CLOUD_RECIPE_IMAGE_URL=https://us-central1-YOUR_PROJECT_ID.cloudfunctions.net/openaiRecipeImage
VITE_CLOUD_SEARCH_URL=https://us-central1-YOUR_PROJECT_ID.cloudfunctions.net/searchCommunityRecipes
VITE_CLOUD_FETCH_URL=https://us-central1-YOUR_PROJECT_ID.cloudfunctions.net/fetchUrl
VITE_CLOUD_FETCH_BROWSER_URL=https://us-central1-YOUR_PROJECT_ID.cloudfunctions.net/fetchUrlBrowser

# Optional: recipe "import from URL" also calls Firebase fetchUrl + fetchUrlBrowser (requires deployed functions).
# Leave unset or false to use only Jina Reader + public proxies — no Functions folder needed.
# VITE_USE_URL_CLOUD_FUNCTIONS=true

# Instructions:
# 1. Copy this file and rename it to .env
# 2. Get your API key from https://platform.openai.com/api-keys
# 3. Replace 'your_openai_api_key_here' with your actual API key
# 4. Never commit the .env file to git (it's already in .gitignore)
